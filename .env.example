# Copy to .env.local for local dev. Set the same keys in Vercel → Settings → Environment Variables.
#
# --- Required for community wall (ideas / votes / comments) ---
# Without BOTH URL + anon key below, posting is disabled in UI and server actions return "not configured".
#
# --- Optional: Resend email ---
# Without RESEND_API_KEY (and sender), posts still succeed but no notification emails are sent.

# Canonical public URL (no trailing slash). Defaults to https://www.familymedvault.com — used for sitemap, metadata, JSON-LD.
# NEXT_PUBLIC_SITE_URL=https://www.familymedvault.com

# Supabase (Settings → API). Use the publishable / anon key for the public client.
# After = write ONLY the URL. Do not repeat the variable name (e.g. …URL=NEXT_PUBLIC_SUPABASE_URL=https://…) — that makes an invalid URL.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only — never expose in client bundles or public repos
# Service role: Settings → API → service_role (bypasses RLS for community admin delete / pin)
SUPABASE_SERVICE_ROLE_KEY=

# Long random string. Used to log in at /community/admin and to salt IP hashes if RATE_LIMIT_IP_SALT is unset
COMMUNITY_ADMIN_SECRET=

# Separate password for /apps/admin (store links CRUD + JSON import). Unrelated to community admin.
# APPS_ADMIN_SECRET=

# Optional: separate secret for IP hashing (defaults to COMMUNITY_ADMIN_SECRET)
RATE_LIMIT_IP_SALT=

# Community submit rate limit (per hashed IP, sliding window)
# COMMUNITY_RATE_LIMIT_MAX=5
# COMMUNITY_RATE_LIMIT_WINDOW_MS=3600000

# Comments per browser client_id per hour (default 25)
# COMMUNITY_COMMENT_RATE_LIMIT_MAX=25

# Cloudflare Turnstile — set BOTH to enforce on /community idea submissions only (recommended for production)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Extra comma-separated substrings to block in posts/comments (case-insensitive)
# COMMUNITY_BLOCKED_SUBSTRINGS=

# Email (Resend) — new posts/comments notify admins; optional receipt to author if email provided
# https://resend.com — create API key and verify a sending domain for production
# RESEND_API_KEY=
# From address (recommended). If omitted, code uses onboarding@resend.dev (Resend test rules apply).
# RESEND_FROM_EMAIL="FamilyMedVault <community@yourdomain.com>"
# Required for admin alerts — comma-separated (without this, posts still work but admins get no mail)
# COMMUNITY_NOTIFY_EMAIL=you@example.com
# Set to 0 to disable automatic receipt emails to the poster when they leave an email (admins still get alerts if configured)
# COMMUNITY_NOTIFY_AUTHOR=1

# --- AmpNest web booking (/ampnest/book) — same Firebase project as AmpNest app ---
# NEXT_PUBLIC_AMPNEST_FIREBASE_API_KEY=
# NEXT_PUBLIC_AMPNEST_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_AMPNEST_FIREBASE_DATABASE_URL=
# NEXT_PUBLIC_AMPNEST_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_AMPNEST_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_AMPNEST_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_AMPNEST_FIREBASE_APP_ID=
# Optional: Firebase Cloud Function sendSms URL (Twilio)
# NEXT_PUBLIC_AMPNEST_SMS_WEBHOOK_URL=

# --- TeLog Tesla China OAuth token proxy (/api/telog/token) ---
# Server only — never expose client_secret or proxy key in the mobile app
# TESLA_CN_CLIENT_ID=836d4267-ee37-4f22-96c2-452d50768745
# TESLA_CN_CLIENT_SECRET=
# TESLA_CN_AUTH_PROXY_KEY=   # random string; TeLog app sends Authorization: Bearer <key>

# --- TeLog 高德逆地理代理 (/api/telog/geocode) ---
# 高德开放平台 → 应用管理 → Web 服务 Key（需勾选「Web 服务」）
# AMAP_WEB_KEY=

# --- TeLog 电池匿名分位池 (/api/telog/battery-peer) ---
# 复用 TESLA_CN_AUTH_PROXY_KEY；仅上传 modelKey + SOH%，不含 VIN

# --- TeLog 驾驶评分匿名分位池 (/api/telog/driving-peer) ---
# 复用 TESLA_CN_AUTH_PROXY_KEY；仅上传 modelKey + score，不含 VIN
